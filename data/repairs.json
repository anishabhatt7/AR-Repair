          "estimated_time": "45 minutes",
          "safety_warnings": ["Do not use bleach or harsh chemicals"],
          "steps": [
            {
              "instruction": "Empty the water reservoir completely",
              "visual_cues": ["water tank", "pour out water"]
            },
            {
              "instruction": "Fill the reservoir with white vinegar (or Keurig descaling solution) up to the MAX line",
              "visual_cues": ["MAX fill line", "reservoir"]
            },
            {
              "instruction": "Place a large mug on the drip tray. Run brew cycles (no K-Cup) until the reservoir is empty",
              "visual_cues": ["drip tray", "mug", "brew button"]
            },
            {
              "instruction": "Fill the reservoir with fresh water and run at least 3 rinse cycles (no K-Cup)",
              "visual_cues": ["fresh water", "brew button"]
            },
            {
              "instruction": "The descale light should turn off. If not, repeat the vinegar cycle",
              "visual_cues": ["descale indicator light"]
            }
          ]
        }
